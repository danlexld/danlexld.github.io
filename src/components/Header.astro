---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<p class="brand"><a href="/">{SITE_TITLE}</a></p>
	<p class="tagline">Recht · Referendariat · München</p>
	<div class="rules" aria-hidden="true">
		<div class="rule-gold"></div>
		<div class="rule-ink"></div>
	</div>
	<nav>
		<HeaderLink href="/">Startseite</HeaderLink>
		<HeaderLink href="/blog">Blog</HeaderLink>
		<HeaderLink href="/about">Über mich</HeaderLink>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 48px 1em 0;
		background: var(--paper);
		text-align: center;
	}
	.brand {
		margin: 0 0 6px;
		font-family: var(--font-serif);
		font-weight: 700;
		font-size: 1.35em;
		letter-spacing: 0.01em;
	}
	.brand a {
		color: rgb(var(--black));
		text-decoration: none;
	}
	.tagline {
		margin: 0 0 24px;
		font-size: 0.625em;
		text-transform: uppercase;
		letter-spacing: 0.22em;
		color: rgb(var(--gray));
	}
	.rules {
		max-width: 1048px;
		margin: 0 auto;
	}
	.rule-gold {
		border-top: 3px solid var(--gold);
	}
	.rule-ink {
		border-top: 1px solid rgb(var(--black));
		margin-top: 3px;
	}
	nav {
		display: flex;
		justify-content: center;
		gap: 40px;
		padding: 16px 0;
		border-bottom: 1px solid rgb(var(--gray-light));
		max-width: 1048px;
		margin: 0 auto;
	}
	nav a {
		font-size: 0.675em;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: rgb(var(--black));
		text-decoration: none;
	}
	nav a:hover {
		color: var(--accent);
	}
	nav a.active {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		header {
			padding-top: 32px;
		}
		nav {
			gap: 24px;
		}
	}
</style>
