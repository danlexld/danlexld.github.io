---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<div class="topbar" aria-hidden="true"></div>
<header>
	<div class="brand-block">
		<p class="brand"><a href="/">{SITE_TITLE}</a></p>
		<p class="tagline">Recht · Referendariat · München</p>
	</div>
	<nav>
		<HeaderLink href="/">Startseite</HeaderLink>
		<HeaderLink href="/blog">Blog</HeaderLink>
		<HeaderLink href="/about">Über mich</HeaderLink>
	</nav>
</header>
<style>
	.topbar {
		height: 3px;
		background: var(--gold);
	}
	header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 24px 72px;
		background: var(--paper);
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.brand {
		margin: 0;
		font-family: var(--font-serif);
		font-weight: 700;
		font-size: 21px;
		line-height: 1.2;
	}
	.brand a {
		color: rgb(var(--black));
		text-decoration: none;
	}
	.tagline {
		margin: 3px 0 0;
		font-size: 11px;
		text-transform: uppercase;
		letter-spacing: 0.16em;
		color: rgb(var(--gray));
	}
	nav {
		display: flex;
		gap: 34px;
	}
	nav a {
		font-size: 15px;
		color: rgb(var(--black));
		text-decoration: none;
		padding-bottom: 6px;
		border-bottom: 2px solid transparent;
	}
	nav a:hover {
		color: var(--accent);
	}
	nav a.active {
		border-bottom-color: var(--gold);
	}
	@media (max-width: 640px) {
		header {
			flex-direction: column;
			align-items: stretch;
			padding: 0;
		}
		.brand-block {
			padding: 18px 20px 14px;
			border-bottom: 1px solid rgb(var(--gray-light));
		}
		.brand {
			font-size: 18px;
		}
		.tagline {
			margin-top: 2px;
			font-size: 10px;
		}
		nav {
			gap: 24px;
			padding: 0 20px;
		}
		nav a {
			font-size: 14px;
			padding: 12px 0 10px;
		}
	}
</style>
