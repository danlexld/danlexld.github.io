---
const today = new Date();
---

<footer>
	<span>&copy; {today.getFullYear()} Daniel Thiel</span>
	<div class="legal-links">
		<a href="/impressum">Impressum</a>
		<a href="/datenschutz">Datenschutz</a>
		<a href="/rss.xml">RSS</a>
	</div>
</footer>
<style>
	footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 26px 72px;
		border-top: 1px solid rgb(var(--gray-light));
		font-size: 14px;
		color: rgb(var(--gray));
	}
	.legal-links {
		display: flex;
		gap: 24px;
	}
	a {
		color: rgb(var(--gray));
		text-decoration: none;
	}
	a:hover {
		color: var(--accent);
	}
	@media (max-width: 640px) {
		footer {
			flex-direction: column;
			gap: 8px;
			padding: 20px;
			font-size: 13px;
		}
		.legal-links {
			gap: 18px;
		}
	}
</style>
