---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { readingMinutes?: number };

const { title, description, pubDate, updatedDate, category, readingMinutes } = Astro.props;

const postSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description: description,
	datePublished: pubDate.toISOString(),
	...(updatedDate && { dateModified: updatedDate.toISOString() }),
	inLanguage: 'de',
	mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
	author: {
		'@type': 'Person',
		name: 'Daniel Thiel',
		url: Astro.site?.toString(),
	},
};
---

<html lang="de">
	<head>
		<BaseHead title={title} description={description} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(postSchema)} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<a class="back" href="/blog">← Alle Beiträge</a>
				<p class="meta">
					<FormattedDate date={pubDate} />{category && <> · {category}</>}{
						readingMinutes && <> · {readingMinutes} Min. Lesezeit</>
					}
				</p>
				<h1>{title}</h1>
				{
					updatedDate && (
						<p class="updated">
							Zuletzt aktualisiert am <FormattedDate date={updatedDate} />
						</p>
					)
				}
				<div class="gold-rule" aria-hidden="true"></div>
				<div class="prose">
					<slot />
				</div>
				<aside class="post-contact">
					<p>
						Fragen oder Anmerkungen zum Beitrag? Schreib mir gern per
						<a href="mailto:danlex.ld@gmail.com">E-Mail</a> oder auf
						<a href="https://www.linkedin.com/in/daniel-thiel-998a98316/">LinkedIn</a> — ich freue
						mich über den Austausch.
					</p>
				</aside>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 720px;
		margin: 0 auto;
		padding: 64px 20px 96px;
		width: 100%;
	}
	.back {
		font-size: 14px;
		font-weight: 700;
		color: var(--accent);
		text-decoration: none;
	}
	.back:hover {
		color: var(--accent-dark);
	}
	.meta {
		margin: 36px 0 0;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}
	h1 {
		margin: 16px 0 0;
		font-size: 44px;
		font-weight: 600;
		line-height: 1.18;
		letter-spacing: -0.015em;
	}
	.updated {
		margin: 14px 0 0;
		font-size: 14px;
		font-style: italic;
		color: rgb(var(--gray));
	}
	.gold-rule {
		width: 76px;
		height: 3px;
		background: var(--gold);
		margin: 32px 0 36px;
	}
	.post-contact {
		border-top: 2px solid var(--gold);
		margin-top: 40px;
		padding-top: 18px;
	}
	.post-contact p {
		margin: 0;
		font-size: 16px;
		line-height: 1.7;
		color: rgb(var(--gray-dark));
	}
	@media (max-width: 640px) {
		main {
			padding: 32px 20px 48px;
		}
		.back {
			font-size: 13px;
		}
		.meta {
			margin-top: 24px;
			font-size: 11px;
			letter-spacing: 0.14em;
		}
		h1 {
			margin-top: 10px;
			font-size: 27px;
			line-height: 1.22;
		}
		.gold-rule {
			width: 56px;
			margin: 22px 0 24px;
		}
	}
</style>
