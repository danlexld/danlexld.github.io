---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead
			title="Blog"
			description="Alle Beiträge: Recht, Referendariat und juristisches Lernen — verständlich aufgeschrieben von Daniel Thiel."
		/>
	</head>
	<body>
		<Header />
		<main>
			<p class="kicker">Blog</p>
			<h1>Alle Beiträge</h1>
			<div class="gold-rule" aria-hidden="true"></div>
			{
				posts.map((post, i) => (
					<a class="post-row" href={`/blog/${post.id}/`}>
						<span class="num">{String(i + 1).padStart(2, '0')}</span>
						<span class="post-info">
							<span class="meta">
								<FormattedDate date={post.data.pubDate} />
								{post.data.category && <> · {post.data.category}</>}
							</span>
							<span class="post-title">{post.data.title}</span>
							<span class="excerpt">{post.data.description}</span>
						</span>
					</a>
				))
			}
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 920px;
		margin: 0 auto;
		padding: 80px 72px 96px;
		width: 100%;
	}
	.kicker {
		margin: 0;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
	}
	h1 {
		margin: 14px 0 0;
		font-size: 46px;
		font-weight: 600;
		letter-spacing: -0.015em;
	}
	.gold-rule {
		width: 76px;
		height: 3px;
		background: var(--gold);
		margin: 28px 0 12px;
	}
	.post-row {
		display: grid;
		grid-template-columns: 88px 1fr;
		gap: 28px;
		padding: 36px 0;
		border-bottom: 1px solid rgb(var(--gray-light));
		text-decoration: none;
	}
	.num {
		font-family: var(--font-serif);
		font-size: 44px;
		line-height: 1;
		color: var(--gold);
	}
	.post-info {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}
	.meta {
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: rgb(var(--gray));
	}
	.post-title {
		font-family: var(--font-serif);
		font-size: 29px;
		font-weight: 600;
		line-height: 1.25;
		color: rgb(var(--black));
	}
	.post-row:hover .post-title {
		color: var(--accent);
	}
	.excerpt {
		font-size: 17px;
		line-height: 1.7;
		color: rgb(var(--gray-dark));
		max-width: 62ch;
	}
	@media (max-width: 640px) {
		main {
			padding: 40px 20px 48px;
		}
		h1 {
			margin-top: 10px;
			font-size: 30px;
		}
		.gold-rule {
			width: 56px;
			margin: 20px 0 4px;
		}
		.post-row {
			display: flex;
			flex-direction: column;
			gap: 8px;
			padding: 22px 0;
		}
		.num {
			display: none;
		}
		.meta {
			font-size: 12px;
		}
		.post-title {
			font-size: 20px;
			line-height: 1.3;
		}
		.excerpt {
			font-size: 15px;
			line-height: 1.65;
		}
	}
</style>
