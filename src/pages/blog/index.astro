---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead
			title="Blog"
			description="Alle Beiträge: Recht, Referendariat und juristisches Lernen — verständlich aufgeschrieben von Daniel Thiel."
		/>
	</head>
	<body>
		<Header />
		<main>
			<h1>Alle Beiträge</h1>
			<section>
				{
					posts.map((post, i) => (
						<a class="post-row" href={`/blog/${post.id}/`}>
							<span class="num">{String(i + 1).padStart(2, '0')}</span>
							<span class="post-info">
								<span class="post-title">{post.data.title}</span>
								<span class="post-description">{post.data.description}</span>
							</span>
							<span class="date">
								<FormattedDate date={post.data.pubDate} />
							</span>
						</a>
					))
				}
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 800px;
		max-width: calc(100% - 2em);
		padding: 64px 0 48px;
	}
	h1 {
		font-size: 2em;
		text-align: center;
		margin-bottom: 1.2em;
	}
	.post-row {
		display: flex;
		align-items: baseline;
		gap: 20px;
		padding: 26px 0;
		border-bottom: 1px solid rgb(var(--gray-light));
		text-decoration: none;
	}
	.post-row:first-of-type {
		border-top: 1px solid rgb(var(--gray-light));
	}
	.num {
		font-family: var(--font-serif);
		font-size: 0.85em;
		color: var(--gold);
		min-width: 28px;
	}
	.post-info {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.post-title {
		font-family: var(--font-serif);
		font-weight: 600;
		font-size: 1.15em;
		line-height: 1.3;
		color: rgb(var(--black));
	}
	.post-description {
		font-size: 0.8em;
		line-height: 1.55;
		color: rgb(var(--gray-dark));
	}
	.date {
		font-size: 0.75em;
		color: rgb(var(--gray));
		white-space: nowrap;
	}
	.post-row:hover .post-title,
	.post-row:hover .num {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		main {
			padding-top: 40px;
		}
		.post-row {
			flex-wrap: wrap;
			gap: 8px 16px;
		}
		.post-info {
			flex-basis: calc(100% - 44px);
		}
		.date {
			margin-left: 44px;
		}
	}
</style>
