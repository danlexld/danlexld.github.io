---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Hi, I'm Daniel 👋</h1>
			<p>
				Welcome to my corner of the internet. I write about the things I build, learn, and find
				interesting.
			</p>
			<p>
				Want to know more about me? Head over to the <a href="/about">about page</a>, or check out
				my latest posts on the <a href="/blog">blog</a>.
			</p>
		</main>
		<Footer />
	</body>
</html>
