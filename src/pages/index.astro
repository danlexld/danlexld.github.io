---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Daniel Thiel',
	url: Astro.site?.toString(),
	jobTitle: 'Rechtsreferendar',
	worksFor: {
		'@type': 'Organization',
		name: 'Oberlandesgericht München',
	},
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'München',
		addressCountry: 'DE',
	},
	email: 'mailto:danlex.ld@gmail.com',
	sameAs: ['https://github.com/danlexld'],
};
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>Wer Recht erklären will, muss es zuerst selbst verstehen.</h1>
				<div class="ornament" aria-hidden="true">
					<span class="line"></span>
					<span class="diamond"></span>
					<span class="line"></span>
				</div>
				<p class="intro">
					Hallo, ich bin Daniel — Rechtsreferendar am OLG München. Dieser Blog ist mein Versuch,
					das Referendariat und die Fragen, die mir dabei begegnen, so aufzuschreiben, dass sie
					jeder versteht. Ohne Fachchinesisch, ohne Fußnotenapparat. Wenn du wissen willst, wer
					hinter den Texten steckt: <a href="/about">hier stelle ich mich vor</a>.
				</p>
			</section>
			<section class="content">
				<div class="posts">
					<h2>Aus dem Blog</h2>
					{
						posts.map((post, i) => (
							<a class="post-row" href={`/blog/${post.id}/`}>
								<span class="num">{String(i + 1).padStart(2, '0')}</span>
								<span class="post-title">{post.data.title}</span>
								<span class="leader" aria-hidden="true" />
								<span class="date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						))
					}
					<a class="all-posts" href="/blog">Alle Beiträge →</a>
				</div>
				<aside>
					<div>
						<h3>Aktuell</h3>
						<p>Zivilstation am Landgericht München I. Die ersten Beiträge dazu sind in Arbeit.</p>
					</div>
					<div>
						<h3>Kontakt</h3>
						<div class="contact-links">
							<a href="mailto:danlex.ld@gmail.com">E-Mail schreiben</a>
							<a href="https://github.com/danlexld">GitHub-Profil</a>
						</div>
					</div>
				</aside>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 1048px;
		max-width: calc(100% - 2em);
		padding: 84px 0 24px;
	}
	.hero {
		text-align: center;
	}
	.hero h1 {
		margin: 0 auto;
		max-width: 22ch;
		font-size: 2.5em;
		line-height: 1.18;
		letter-spacing: -0.01em;
		text-wrap: balance;
	}
	.ornament {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 12px;
		margin: 38px 0;
	}
	.ornament .line {
		width: 48px;
		height: 1px;
		background: var(--gold);
	}
	.ornament .diamond {
		width: 6px;
		height: 6px;
		background: var(--gold);
		transform: rotate(45deg);
	}
	.intro {
		margin: 0 auto;
		max-width: 60ch;
		text-align: left;
		font-size: 0.95em;
		line-height: 1.75;
	}
	.intro::first-letter {
		float: left;
		font-family: var(--font-serif);
		font-weight: 600;
		font-size: 3.4em;
		line-height: 0.85;
		color: rgb(var(--black));
		padding: 6px 10px 0 0;
	}
	.content {
		display: grid;
		grid-template-columns: 1fr 300px;
		gap: 72px;
		padding: 56px 0 40px;
	}
	.posts h2,
	aside h3 {
		margin: 0 0 8px;
		font-family: var(--font-atkinson);
		font-size: 0.65em;
		text-transform: uppercase;
		letter-spacing: 0.18em;
		color: rgb(var(--gray));
		font-weight: 700;
	}
	aside h3 {
		margin-bottom: 10px;
	}
	.post-row {
		display: flex;
		align-items: baseline;
		gap: 16px;
		padding: 22px 0;
		border-bottom: 1px solid rgb(var(--gray-light));
		text-decoration: none;
	}
	.post-row .num {
		font-family: var(--font-serif);
		font-size: 0.85em;
		color: var(--gold);
		min-width: 28px;
	}
	.post-row .post-title {
		font-family: var(--font-serif);
		font-weight: 600;
		font-size: 1.1em;
		line-height: 1.3;
		color: rgb(var(--black));
	}
	.post-row .leader {
		flex: 1;
		border-bottom: 1px dotted #d5cebf;
		transform: translateY(-5px);
		min-width: 40px;
	}
	.post-row .date {
		font-size: 0.75em;
		color: rgb(var(--gray));
		white-space: nowrap;
	}
	.post-row:hover .post-title,
	.post-row:hover .num {
		color: var(--accent);
	}
	.all-posts {
		display: inline-block;
		margin: 20px 0 0;
		font-size: 0.8em;
		color: var(--accent);
		text-decoration: none;
	}
	.all-posts:hover {
		color: var(--accent-dark);
		text-decoration: underline;
	}
	aside {
		border-left: 1px solid rgb(var(--gray-light));
		padding-left: 32px;
		display: flex;
		flex-direction: column;
		gap: 32px;
	}
	aside p {
		margin: 0;
		font-size: 0.8em;
		line-height: 1.65;
	}
	.contact-links {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}
	.contact-links a {
		font-size: 0.8em;
	}
	@media (max-width: 860px) {
		main {
			padding-top: 48px;
		}
		.hero h1 {
			font-size: 1.8em;
		}
		.content {
			grid-template-columns: 1fr;
			gap: 40px;
		}
		aside {
			border-left: none;
			border-top: 1px solid rgb(var(--gray-light));
			padding-left: 0;
			padding-top: 32px;
		}
		.post-row .leader {
			display: none;
		}
	}
</style>
