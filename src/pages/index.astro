---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const posts = allPosts.slice(0, 3);

// Rechtsgebiete aus den Post-Kategorien — wächst automatisch mit neuen Beiträgen
const rechtsgebiete = [
	...new Set(allPosts.map((p) => p.data.category).filter((c) => c && c !== 'In eigener Sache')),
];

const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	'@id': `${Astro.site}#daniel-thiel`,
	name: 'Daniel Thiel',
	url: Astro.site?.toString(),
	knowsAbout: ['Recht', ...rechtsgebiete],
	jobTitle: 'Rechtsreferendar',
	worksFor: {
		'@type': 'Organization',
		name: 'Oberlandesgericht München',
	},
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'München',
		addressCountry: 'DE',
	},
	email: 'mailto:danlex.ld@gmail.com',
	sameAs: [
		'https://github.com/danlexld',
		'https://www.linkedin.com/in/daniel-thiel-998a98316/',
	],
};
---

<!doctype html>
<html lang="de">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div>
					<p class="kicker">Rechtsreferendar am OLG München</p>
					<h1>
						Wer Recht erklären will, muss es zuerst selbst <em>verstehen</em>.
					</h1>
					<div class="gold-rule" aria-hidden="true"></div>
					<p class="intro">
						Hallo, ich bin Daniel — Rechtsreferendar am OLG München. Dieser Blog ist mein
						Versuch, das Referendariat und die Fragen, die mir dabei begegnen, so aufzuschreiben,
						dass sie jeder versteht. Ohne Fachchinesisch, ohne Fußnotenapparat. Wenn du wissen
						willst, wer hinter den Texten steckt: <a href="/about">hier stelle ich mich vor</a>.
					</p>
				</div>
			</section>
			<section class="content">
				<div class="posts">
					<div class="label-row">
						<span class="label">Aus dem Blog</span>
						<span class="label-line" aria-hidden="true"></span>
					</div>
					{
						posts.map((post, i) => (
							<a class="post-row" href={`/blog/${post.id}/`}>
								<span class="num">{String(i + 1).padStart(2, '0')}</span>
								<span class="post-title">{post.data.title}</span>
								<span class="date">
									<FormattedDate date={post.data.pubDate} />
								</span>
							</a>
						))
					}
					<a class="all-posts" href="/blog">Alle Beiträge →</a>
				</div>
				<aside>
					<div class="side-block">
						<h2>Aktuell</h2>
						<p>Zivilstation am Landgericht München I. Die ersten Beiträge dazu sind in Arbeit.</p>
					</div>
					<div class="side-block">
						<h2>Kontakt</h2>
						<div class="contact-links">
							<a href="mailto:danlex.ld@gmail.com">E-Mail schreiben</a>
							<a href="https://www.linkedin.com/in/daniel-thiel-998a98316/">LinkedIn</a>
						</div>
					</div>
				</aside>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: 100%;
		max-width: 1440px;
		margin: 0 auto;
		padding: 0;
	}
	.hero,
	.content {
		display: grid;
		grid-template-columns: 1fr 340px;
		gap: 96px;
		align-items: start;
	}
	.hero {
		padding: 88px 72px 72px;
	}
	.content {
		padding: 0 72px 88px;
	}
	.kicker {
		margin: 0;
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--accent);
	}
	h1 {
		margin: 20px 0 0;
		max-width: 18ch;
		font-size: 56px;
		font-weight: 600;
		line-height: 1.12;
		letter-spacing: -0.015em;
	}
	h1 em {
		font-style: italic;
		text-decoration: underline;
		text-decoration-color: var(--gold);
		text-decoration-thickness: 3px;
		text-underline-offset: 9px;
	}
	.gold-rule {
		width: 76px;
		height: 3px;
		background: var(--gold);
		margin: 34px 0 28px;
	}
	.intro {
		margin: 0;
		max-width: 56ch;
		font-size: 19px;
		line-height: 1.75;
	}
	.label-row {
		display: flex;
		align-items: center;
		gap: 16px;
	}
	.label,
	.side-block h2 {
		font-family: var(--font-atkinson);
		font-size: 13px;
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgb(var(--gray));
		margin: 0;
	}
	.label-line {
		flex: 1;
		height: 1px;
		background: rgb(var(--gray-light));
	}
	.post-row {
		display: grid;
		grid-template-columns: 72px 1fr auto;
		gap: 24px;
		align-items: baseline;
		padding: 28px 0;
		border-bottom: 1px solid rgb(var(--gray-light));
		text-decoration: none;
	}
	.post-row .num {
		font-family: var(--font-serif);
		font-size: 30px;
		color: var(--gold);
	}
	.post-row .post-title {
		font-family: var(--font-serif);
		font-size: 24px;
		font-weight: 600;
		line-height: 1.3;
		color: rgb(var(--black));
	}
	.post-row:hover .post-title {
		color: var(--accent);
	}
	.post-row .date {
		font-size: 14px;
		color: rgb(var(--gray));
		white-space: nowrap;
	}
	.all-posts {
		display: inline-block;
		margin-top: 26px;
		font-size: 16px;
		font-weight: 700;
		color: var(--accent);
		text-decoration: none;
	}
	.all-posts:hover {
		color: var(--accent-dark);
	}
	aside {
		display: flex;
		flex-direction: column;
		gap: 44px;
	}
	.side-block {
		border-top: 2px solid var(--gold);
		padding-top: 18px;
	}
	.side-block h2 {
		color: rgb(var(--black));
	}
	.side-block p {
		margin: 12px 0 0;
		font-size: 16px;
		line-height: 1.7;
	}
	.contact-links {
		display: flex;
		flex-direction: column;
		gap: 10px;
		margin-top: 14px;
	}
	.contact-links a {
		font-size: 16px;
		width: max-content;
	}
	@media (max-width: 900px) {
		.hero,
		.content {
			grid-template-columns: 1fr;
			gap: 36px;
		}
	}
	@media (max-width: 640px) {
		.hero {
			padding: 44px 20px 36px;
		}
		.content {
			padding: 0 20px 40px;
		}
		.kicker {
			font-size: 11px;
		}
		h1 {
			margin-top: 14px;
			font-size: 32px;
			line-height: 1.18;
		}
		h1 em {
			text-decoration-thickness: 2px;
			text-underline-offset: 6px;
		}
		.gold-rule {
			width: 56px;
			margin: 22px 0 18px;
		}
		.intro {
			font-size: 16px;
			line-height: 1.7;
		}
		.label,
		.side-block h2 {
			font-size: 11px;
		}
		.post-row {
			grid-template-columns: 40px 1fr;
			gap: 14px;
			padding: 18px 0;
		}
		.post-row .num {
			font-size: 20px;
		}
		.post-row .post-title {
			font-size: 18px;
		}
		.post-row .date {
			grid-column: 2;
			font-size: 13px;
		}
		.all-posts {
			margin-top: 18px;
			font-size: 15px;
		}
		aside {
			gap: 28px;
		}
		.side-block {
			padding-top: 14px;
		}
		.side-block p {
			margin-top: 8px;
			font-size: 15px;
			line-height: 1.65;
		}
		.contact-links {
			flex-direction: row;
			gap: 20px;
			margin-top: 10px;
		}
		.contact-links a {
			font-size: 15px;
		}
	}
</style>
